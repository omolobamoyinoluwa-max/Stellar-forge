{
  "name": "stellar-forge",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "StellarForge - Stellar Token Deployer",
  "scripts": {
    "prepare": "husky",
    "release": "semantic-release",
    "contract:compile": "cd contracts/token-factory && cargo build --target wasm32-unknown-unknown --release",
    "frontend:dev": "cd frontend && npm run dev",
    "start": "npm run contract:compile && npm run frontend:dev",
    "dev:all": "concurrently -n contract,frontend -c cyan,green \"npm run contract:compile\" \"npm run frontend:dev\""
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.0.0",
    "prettier": "^3.3.3",
    "semantic-release": "^25.0.3"
  },
  "dependencies": {
    "@sentry/react": "^10.46.0"
  }
}
